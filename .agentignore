# =============================================================================
# Resonance 7 - Agent Ignore Rules
# =============================================================================
# Protects critical files and directories from automatic agent modification
# Note: Agents should check this file before modifying any files or directories
# Referenced in agent_foundation.json file_safety protocol


# =============================================================================
# Core Foundation Files
# =============================================================================
# Protect core protocol and configuration files (modify only with explicit user request)

.cursor/rules/agent_onboarding.mdc
.cursor/commands/foundation.md
library/agent_foundation.json


# =============================================================================
# Essential Scripts
# =============================================================================
# Protect scripts that are essential to Resonance 7 functionality

library/tools/scripts/


# =============================================================================
# Configuration Files
# =============================================================================
# Protect ignore and configuration files (prevent accidental modification)

library/templates/
.agentignore
.cursorignore
.gitattributes
.gitignore


# =============================================================================
# Shared Resonance 7 Resources
# =============================================================================
# Protect user-curated documentation modules (runtime under library/docs/).

library/docs/


# =============================================================================
# Version Control
# =============================================================================
# Protect version control system files

.git/


# =============================================================================
# Knowledge Base Databases
# =============================================================================
# DB files live under library/databases/db/ (see library/databases/README.md).
# Query via MCP; update via ingest/migration scripts -- not casual direct edits.

library/databases/db/*.db


# =============================================================================
# IDE and Editor Configuration
# =============================================================================
# Protect IDE-specific configuration (usually user-specific)

.cursor/settings.json
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================
# Protect OS-specific files (not needed for agent modification)

.DS_Store
Thumbs.db
desktop.ini
*.lnk

# =============================================================================
# Build Artifacts
# =============================================================================
# Protect build outputs (regenerated, not edited)

__pycache__/
*.pyc
*.pyo
*.pyd
*.so
dist/
build/
*.egg-info/
.eggs/
wheels/
*.whl
*.egg


# =============================================================================
# Virtual Environments
# =============================================================================
# Protect virtual environments (system-managed)

.env
.venv/
venv/
env/
ENV/


# =============================================================================
# Test Artifacts
# =============================================================================
# Protect test outputs (regenerated, not edited)

.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
.ipynb_checkpoints/


# =============================================================================
# Log Files
# =============================================================================
# Protect log files (append-only, not edited)

*.log


# =============================================================================
# Temporary Files
# =============================================================================
# Protect temporary files (system-managed)

*.tmp
*.temp
*.bak
*.backup


# =============================================================================
# Project-Specific Protected Files
# =============================================================================
# Add project-specific files/directories that should never be auto-modified
# Example patterns (uncomment and customize as needed):

# projects/*/secrets/
# projects/*/credentials/
# projects/*/config/production.yaml
# projects/*/private/


# =============================================================================
# Override Parent-Level Ignores
# =============================================================================
# Use ! to negate patterns from higher-level .agentignore files
# Example: !special_tools/  (re-enables a directory ignored at parent level)
# Note: This section is typically used in project-level .agentignore files
