# =============================================================================
# Resonance 7 - Git Ignore Rules
# =============================================================================
# Excludes high-churn content while preserving skeleton docs and core tools.


# =============================================================================
# Cursor (local project config)
# =============================================================================
# Machine-specific; use library/tools/scripts/setup_database.py to generate locally.

.cursor/mcp.json


# =============================================================================
# Documentation Policy
# =============================================================================
# Exclude library docs by default, but keep README breadcrumbs tracked.

library/docs/**
!library/docs/**/
!library/docs/**/README.md


# =============================================================================
# Session Policy
# =============================================================================
# Exclude session payloads, keep docs tracked.

library/sessions/archived/**
library/sessions/current/**
library/sessions/recent/**
!library/sessions/README.md


# =============================================================================
# Tool Policy
# =============================================================================
# Exclude library tools by default, but keep README breadcrumbs and core tools.

library/tools/**
!library/tools/**/
!library/tools/**/README.md
!library/tools/mcp_sqlite_server/**
!library/tools/scripts/session_tools.py
!library/tools/scripts/setup_database.py
!library/tools/scripts/setup_workspace.py


# =============================================================================
# Database Policy
# =============================================================================
# Exclude library databases by default; track README breadcrumbs, schema, ingest, and default DB placeholder.

library/databases/**
!library/databases/**/
!library/databases/README.md
!library/databases/workspace_mcp_servers.md
!library/databases/db/session_logs.db
!library/databases/schemas/session_logs.sql
!library/databases/scripts/README.md
!library/databases/scripts/ingest_session_logs.py
library/databases/sources/**


# =============================================================================
# Workspace pairing (local machine paths)
# =============================================================================

projects/*.code-workspace


# =============================================================================
# Scratch and runtime data
# =============================================================================
# tests/ is agent/human scratch (see README); created by setup_workspace.py.
# Temporary .md files (drafts, one-off notes) belong here if created -- not repo root.

tests/**


# =============================================================================
# IDE and Editor Files
# =============================================================================

.cursor/settings.json
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini
*.lnk


# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/


# =============================================================================
# Node.js (if used in projects)
# =============================================================================

node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# Temporary and Log Files
# =============================================================================

*.log
*.tmp
*.temp
*.bak
*.backup
