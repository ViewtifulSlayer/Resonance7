# Resonance 7 - Git Ignore Rules
# Excludes user-specific content while preserving directory structure

# =============================================================================
# Sessions
# =============================================================================
# Exclude actual session log files, but preserve directory structure and READMEs
sessions/archived/*
sessions/current/*
sessions/recent/*
!sessions/README.md
!sessions/*/README.md

# =============================================================================
# Projects
# =============================================================================
# Exclude user projects (downloaded on-demand)
projects/*
# But preserve the projects/ directory structure
!projects/INDEX.md
!projects/README.md

# =============================================================================
# Resource Modules
# =============================================================================
# Exclude downloaded modules (downloaded on-demand)
library/resources/*
# But preserve the resources/ directory structure
!library/resources/README.md
!library/resources/*/README.md
!library/resources/*/*/README.md
!library/resources/*/*/*/README.md

# =============================================================================
# Tool Modules
# =============================================================================
# Exclude downloaded modules (downloaded on-demand)
library/tools/*
# But preserve the tools/ directory structure and core tools
!library/tools/README.md
!library/tools/*/README.md
!library/tools/*/*/README.md
!library/tools/*/*/*/README.md
!library/tools/mcp_sqlite_server/
!library/tools/project_tools.py
!library/tools/session_tools.py

# =============================================================================
# IDE and Editor Files
# =============================================================================
# IDE-specific files (optional - users can customize)
.cursor/settings.json
.vscode/
!.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS and System Files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/

# =============================================================================
# Node.js (if used in projects)
# =============================================================================
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Temporary and Log Files
# =============================================================================
*.log
*.tmp
*.temp
*.bak
*.backup
