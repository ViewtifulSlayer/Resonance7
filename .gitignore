# =============================================================================
# Resonance 7 - Git Ignore Rules
# =============================================================================
# Excludes high-churn content while preserving skeleton docs and core tools.


# =============================================================================
# Cursor (local project config)
# =============================================================================
# Preserve only core commands, rules and skills; to generate a local copy of
# .cursor/mcp.json, use library/tools/scripts/setup_database.py.

.cursor/**
!.cursor/commands/foundation.md
!.cursor/commands/help.md
!.cursor/commands/session.md
!.cursor/commands/start.md
!.cursor/rules/agent_onboarding.mdc
!.cursor/rules/workspace_bootstrap.mdc
!.cursor/rules/workspace_first_run.mdc
!.cursor/skills/database-specialist/**
!.cursor/skills/markdown-punctuation/**
!.cursor/skills/mcp-sqlite/**
!.cursor/skills/python-expert/**


# =============================================================================
# Documentation Policy
# =============================================================================
# Exclude library docs by default, does not track README breadcrumbs.

library/docs/**


# =============================================================================
# Session Policy
# =============================================================================
# Exclude session log payloads; keep library/sessions/README.md tracked.

library/sessions/archived/**
library/sessions/current/**
library/sessions/recent/**
!library/sessions/README.md


# =============================================================================
# Tool Policy
# =============================================================================
# Exclude library tools by default, but keep core tools.

library/tools/**
!library/tools/README.md
!library/tools/mcp_sqlite_server/
!library/tools/mcp_sqlite_server/**
!library/tools/scripts/
!library/tools/scripts/session_tools.py
!library/tools/scripts/setup_database.py
!library/tools/scripts/setup_workspace.py


# =============================================================================
# Database Policy
# =============================================================================
# Exclude library databases by default; track README breadcrumbs, schema, and
# ingest scripts.

# Ignore everything under library/databases/ except the files listed below.
# Runtime dirs (sources/, db/, etc.) need no extra lines — they stay ignored.

library/databases/**
!library/databases/**/
!library/databases/README.md
!library/databases/workspace_mcp_servers.md
!library/databases/schemas/session_logs.sql
!library/databases/scripts/README.md
!library/databases/scripts/ingest_session_logs.py


# =============================================================================
# Workspace pairing (local machine paths)
# =============================================================================

projects/*.code-workspace


# =============================================================================
# Scratch and runtime data
# =============================================================================
# tests/ is agent/human scratch (see README); created by setup_workspace.py.
# Temporary .md files (drafts, one-off notes) belong here if created -- not repo root.

tests/**


# =============================================================================
# IDE and Editor Files
# =============================================================================

.cursor/settings.json
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini
*.lnk


# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/


# =============================================================================
# Node.js (if used in projects)
# =============================================================================

node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# Temporary and Log Files
# =============================================================================

*.log
*.tmp
*.temp
*.bak
*.backup
