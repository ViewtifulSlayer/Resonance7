# =============================================================================
# Resonance 7 - Git Ignore Rules
# =============================================================================
# Excludes high-churn content while preserving skeleton docs and core tools.


# =============================================================================
# Cursor (local project config)
# =============================================================================
# Machine-specific; use library/tools/setup_mcp_sqlite.py to generate locally.

.cursor/mcp.json


# =============================================================================
# Resource Modules
# =============================================================================
# Exclude library resources by default, but keep README breadcrumbs tracked.

library/resources/**
!library/resources/**/
!library/resources/**/README.md


# =============================================================================
# Tool Modules
# =============================================================================
# Exclude library tools by default, but keep README breadcrumbs and core tools.

library/tools/**
!library/tools/**/
!library/tools/**/README.md
!library/tools/mcp_sqlite_server/**
!library/tools/project_tools.py
!library/tools/session_tools.py
!library/tools/setup_mcp_sqlite.py


# =============================================================================
# Sessions
# =============================================================================
# Exclude session payloads, keep docs tracked.

sessions/archived/**
sessions/current/**
sessions/recent/**
!sessions/README.md
!sessions/**/README.md


# =============================================================================
# Project Overrides
# =============================================================================
# Keep hub repo lean; track project breadcrumb docs only.

projects/**
!projects/**/
!projects/INDEX.md
!projects/README.md
!projects/**/README.md

# To include a specific project in hub tracking, add explicit allow rules, e.g.
# !projects/specific_project/
# !projects/specific_project/**


# =============================================================================
# IDE and Editor Files
# =============================================================================

.cursor/settings.json
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini
*.lnk


# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/


# =============================================================================
# Node.js (if used in projects)
# =============================================================================

node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# Temporary and Log Files
# =============================================================================

*.log
*.tmp
*.temp
*.bak
*.backup
