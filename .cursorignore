# =============================================================================
# Resonance 7 - Cursor IDE Ignore Rules
# =============================================================================
# Excludes build artifacts and large files from indexing while preserving
# path discoverability through README breadcrumbs.
# Note: These patterns affect indexing behavior, not file existence/access.


# =============================================================================
# Documentation Overrides
# =============================================================================
# Exclude library docs by default and add exceptions on project level.
# Example: To include a specific resource directory in indexing:
# !library/docs/*

library/docs/

# Preserve access to README breadcrumbs, even if subdirectories are excluded.

!library/docs/**/
!library/docs/**/README.md


# =============================================================================
# Tool indexing
# =============================================================================
# library/tools/ is indexed (not excluded). README breadcrumbs stay discoverable.
# node_modules and other build outputs are excluded in sections below.

!library/tools/**/
!library/tools/**/README.md


# =============================================================================
# Scratch and runtime data
# =============================================================================
# Align with .gitignore: tests/ scratch and library/databases/sources/ inputs.

tests/**
library/databases/sources/**


# =============================================================================
# Database files (binary)
# =============================================================================
# Paths and aliases: library/databases/README.md and workspace_mcp_servers.md.
# Exclude binary DBs from indexing; query via MCP or read ingest/schema docs.

library/databases/db/*.db


# =============================================================================
# IDE and Editor Files
# =============================================================================
# Exclude IDE-specific configuration files (reduce index noise).

.cursor/mcp.json
.cursor/settings.json
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================
# Exclude OS-specific files (not needed for code indexing).

.DS_Store
Thumbs.db
desktop.ini
*.lnk


# =============================================================================
# Python Build Artifacts
# =============================================================================
# Exclude Python build outputs.

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/


# =============================================================================
# Node.js Build Artifacts
# =============================================================================
# Exclude Node.js dependencies and build outputs.

node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# Temporary and Log Files
# =============================================================================
# Exclude temporary files and logs.

*.log
*.tmp
*.temp
*.bak
*.backup


# =============================================================================
# Cross-Project Build Artifacts
# =============================================================================
# Exclude build/cache outputs anywhere in the workspace.

**/node_modules/
**/dist/
**/build/
**/__pycache__/
**/.venv/
**/venv/
**/env/
**/ENV/
**/*.egg-info/
**/wheels/
**/.pytest_cache/
**/htmlcov/
**/.tox/
**/.hypothesis/
**/.ipynb_checkpoints/
**/.coverage
**/*.py[cod]
**/*.pyd
**/*.so
**/*.egg
**/*.whl
