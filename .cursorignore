# =============================================================================
# Resonance 7 - Cursor IDE Ignore Rules
# =============================================================================
# Excludes build artifacts and large files from indexing while preserving
# path discoverability through README breadcrumbs.
# Note: These patterns affect indexing behavior, not file existence/access.

# =============================================================================
# Resource Module Overrides
# =============================================================================
# Exclude library resources by default, but keep README breadcrumbs indexed.

library/resources/**
!library/resources/**/
!library/resources/**/README.md


# =============================================================================
# Tool Module Overrides
# =============================================================================
# Exclude library tools by default, but keep README breadcrumbs indexed.

library/tools/**
!library/tools/**/
!library/tools/**/README.md


# =============================================================================
# Project Overrides
# =============================================================================
# Exclude inactive projects from indexing.

projects/inactive/**

# Keep project tree discoverable through README breadcrumbs.

projects/**
!projects/**/
!projects/INDEX.md
!projects/README.md
!projects/**/README.md


# =============================================================================
# IDE and Editor Files
# =============================================================================
# Exclude IDE-specific configuration files (reduce index noise).

.cursor/settings.json
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~


# =============================================================================
# OS and System Files
# =============================================================================
# Exclude OS-specific files (not needed for code indexing).

.DS_Store
Thumbs.db
desktop.ini
*.lnk


# =============================================================================
# Python Build Artifacts
# =============================================================================
# Exclude Python build outputs.

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/


# =============================================================================
# Node.js Build Artifacts
# =============================================================================
# Exclude Node.js dependencies and build outputs.

node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# Temporary and Log Files
# =============================================================================
# Exclude temporary files and logs.

*.log
*.tmp
*.temp
*.bak
*.backup


# =============================================================================
# Cross-Project Build Artifacts
# =============================================================================
# Exclude build/cache outputs anywhere in the workspace.

**/node_modules/
**/dist/
**/build/
**/__pycache__/
**/.venv/
**/venv/
**/env/
**/ENV/
**/*.egg-info/
**/wheels/
**/.pytest_cache/
**/htmlcov/
**/.tox/
**/.hypothesis/
**/.ipynb_checkpoints/
**/.coverage
**/*.py[cod]
**/*.pyd
**/*.so
**/*.egg
**/*.whl


# =============================================================================
# Large Data Files
# =============================================================================
# Optionally exclude large database files from indexing.
# Uncomment if needed.

# *.db
# *.sqlite
# *.sqlite3

# Uncomment if you want selected knowledge bases indexed:

# !library/**/*_knowledge_base.db
# !library/**/*.sqlite
# !library/**/*.sqlite3
